            </div>
          </div>
          <span class="van-field__label-collapse">
            <span class="van-field__label-collapse-text">
              Collapse
            </span>
            <i
              class="van-badge__wrapper van-icon van-icon-arrow-down van-field__label-collapse-icon van-field__label-collapse-icon--expanded"
              style="font-size: 12px;"
            >
            </i>
          </span>
        </div>
        <div class="van-field__label-comment">
          Label note remains when collapsed
        </div>
      </div>
      <div class="van-cell__value van-field__value">
        <div class="van-field__body">
          <input
            type="text"
            id="van-field-input"
            class="van-field__control"
            placeholder="Text"
            aria-labelledby="van-field-label"
            data-allow-mismatch="attribute"
          >
        </div>
      </div>
    </div>
  </div>
</div>
`;
